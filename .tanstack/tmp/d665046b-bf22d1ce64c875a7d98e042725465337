import { createFileRoute, redirect, useNavigate } from '@tanstack/react-router'
import { useState } from 'react'
import { useQuery } from '@tanstack/react-query'
import { getCategories } from '../api/categories/categories' // Sizin mövcud kateqoriya API funksiyanız

export const Route = createFileRoute('/admin/')({
  // Təhlükəsizlik Guard-ı: Token yoxdursa login-ə geri atır
  beforeLoad: () => {
    const token = localStorage.getItem('admin_token')
    if (!token) {
      throw redirect({
        to: '/admin/login',
      })
    }
  },
  component: AdminDashboard,
})

function AdminDashboard() {
  const navigate = useNavigate()

  // --- API-dən Kateqoriyaların Çəkilməsi ---
  const { data: serverCategories, isLoading: isCatsLoading } = useQuery({
    queryKey: ['categories'],
    queryFn: getCategories
  })

  // --- Lokal Dövlətlər (States) ---
  const [newsList, setNewsList] = useState([]) // Əlavə edilən xəbərlərin siyahısı
  
  // Form inputları üçün statelər
  const [catInput, setCatInput] = useState('')
  const [editingCatId, setEditingCatId] = useState(null)
  
  const [newsTitle, setNewsTitle] = useState('')
  const [newsContent, setNewsContent] = useState('')
  const [selectedCatId, setSelectedCatId] = useState('')

  // Sol paneldə hansı bölmənin aktiv olduğunu seçmək üçün (Ümumi Baxış, Kateqoriyalar, Xəbər)
  const [activeTab, setActiveTab] = useState('overview')

  // Sistemdən Çıxış funksiyası
  const handleLogout = () => {
    localStorage.removeItem('admin_token') 
    navigate({ to: '/admin/login' }) 
  }

  // --- KATEQORİYA ƏMƏLİYYATLARI (Əlavə et / Yenilə) ---
  const handleSaveCategory = (e) => {
    e.preventDefault()
    if (!catInput.trim()) return

    if (editingCatId) {
      // BURADA: Backend-ə UPDATE (PUT/PATCH) sorğusu göndərilməlidir
      console.log(`Kateqoriya yeniləndi. ID: ${editingCatId}, Yeni ad: ${catInput}`)
      setEditingCatId(null)
    } else {
      // BURADA: Backend-ə yeni kateqoriya üçün POST sorğusu göndərilməlidir
      console.log(`Yeni kateqoriya əlavə olundu: ${catInput}`)
    }
    setCatInput('')
  }

  const handleEditCategoryClick = (id, currentName) => {
    setEditingCatId(id)
    setCatInput(currentName)
    setActiveTab('categories') // İstifadəçini kateqoriya formunun olduğu tab-a gətirir
  }

  const handleDeleteCategory = (id) => {
    if (confirm('Bu kateqoriyanı silmək istədiyinizdən əminsiniz?')) {
      // BURADA: Backend-ə DELETE sorğusu göndərilməlidir
      console.log(`Kateqoriya silindi. ID: ${id}`)
    }
  }

  // --- XƏBƏR ƏMƏLİYYATLARI (Kateqoriya Seçimi İlə) ---
  const handleAddNews = (e) => {
    e.preventDefault()
    if (!newsTitle.trim() || !newsContent.trim() || !selectedCatId) {
      alert('Zəhmət olmasa bütün xanaları doldurun və kateqoriya seçin!')
      return
    }

    // Seçilmiş kateqoriyanın ID-sinə əsasən adını tapırıq
    const selectedCategory = serverCategories?.find((c) => c._id === selectedCatId)

    const newArticle = {
      id: Date.now().toString(),
      title: newsTitle,
      content: newsContent,
      categoryName: selectedCategory ? selectedCategory.name : 'Naməlum',
      catId: selectedCatId
    }

    // Yeni xəbəri lokal siyahıya əlavə edirik (Normalda bura API POST sorğusu olmalıdır)
    setNewsList([newArticle, ...newsList])
    
    // Formu sıfırlayırıq
    setNewsTitle('')
    setNewsContent('')
    setSelectedCatId('')
    alert('Xəbər uğurla əlavə edildi!')
  }

  return (
    <div className="min-h-screen bg-zinc-100 flex flex-col md:flex-row">
      
      {/* SOL PANEL - MENYU */}
      <div className="w-full md:w-64 bg-zinc-900 text-zinc-300 flex flex-col p-6">
        <div className="mb-8">
          <h1 className="text-xl font-bold text-white">Oxu.Az Admin</h1>
          <p className="text-xs text-zinc-500 mt-1">daivd@davidjs.dev</p>
        </div>
        
        <nav className="flex-1 space-y-2">
          <button 
            onClick={() => setActiveTab('overview')}
            className={`w-full text-left px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeTab === 'overview' ? 'bg-zinc-800 text-white' : 'hover:bg-zinc-800/50'}`}
          >
            📊 Ümumi Baxış
          </button>
          <button 
            onClick={() => setActiveTab('categories')}
            className={`w-full text-left px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeTab === 'categories' ? 'bg-zinc-800 text-white' : 'hover:bg-zinc-800/50'}`}
          >
            📁 Kateqoriyalar
          </button>
          <button 
            onClick={() => setActiveTab('news')}
            className={`w-full text-left px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${activeTab === 'news' ? 'bg-zinc-800 text-white' : 'hover:bg-zinc-800/50'}`}
          >
            📰 Xəbər Əlavə Et
          </button>
        </nav>

        <button 
          onClick={handleLogout}
          className="mt-auto w-full bg-red-600/10 hover:bg-red-600/20 text-red-400 py-2 rounded-lg text-sm font-medium transition-colors text-center"
        >
          Çıxış et
        </button>
      </div>

      {/* SAĞ PANEL - KONTENT */}
      <div className="flex-1 p-6 md:p-10 overflow-y-auto">
        
        {/* 1. TAB: ÜMUMİ BAXIŞ */}
        {activeTab === 'overview' && (
          <div>
            <h2 className="text-2xl font-bold text-zinc-800 mb-6">İdarəetmə Paneli</h2>
            
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
              <div className="bg-white p-6 rounded-xl border border-zinc-200 shadow-sm">
                <p className="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Kateqoriyalar</p>
                <p className="text-3xl font-bold text-zinc-800 mt-2">{isCatsLoading ? '...' : serverCategories?.length || 0}</p>
              </div>
              <div className="bg-white p-6 rounded-xl border border-zinc-200 shadow-sm">
                <p className="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Paneldən Əlavə Edilən Xəbərlər</p>
                <p className="text-3xl font-bold text-zinc-800 mt-2">{newsList.length}</p>
              </div>
              <div className="bg-white p-6 rounded-xl border border-zinc-200 shadow-sm">
                <p className="text-xs font-semibold text-zinc-400 uppercase tracking-wider">Status</p>
                <p className="text-3xl font-bold text-green-600 mt-2">Aktiv</p>
              </div>
            </div>

            <div className="bg-white rounded-xl border border-zinc-200 shadow-sm p-6">
              <h3 className="text-base font-bold text-zinc-800 mb-4">Yeni Əlavə Olunan Son Xəbərlər</h3>
              {newsList.length === 0 ? (
                <p className="text-sm text-zinc-400">Hələ ki xəbər əlavə edilməyib.</p>
              ) : (
                <div className="divide-y divide-zinc-100">
                  {newsList.map((news) => (
                    <div key={news.id} className="py-3 flex justify-between items-center">
                      <div>
                        <h4 className="text-sm font-semibold text-zinc-800">{news.title}</h4>
                        <p className="text-xs text-zinc-400 mt-0.5">Məzmun: {news.content.substring(0, 70)}...</p>
                      </div>
                      <span className="bg-zinc-100 text-zinc-600 text-xs px-2.5 py-1 rounded-full font-medium">
                        {news.categoryName}
                      </span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        )}

        {/* 2. TAB: KATEQORİYALAR (CRUD) */}
        {activeTab === 'categories' && (
          <div>
            <h2 className="text-2xl font-bold text-zinc-800 mb-6">Kateqoriya İdarəetməsi</h2>
            
            <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
              {/* Sol Form: Əlavə et / Redaktə et */}
              <div className="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm h-fit">
                <h3 className="text-sm font-bold text-zinc-700 mb-4">
                  {editingCatId ? '📝 Kateqoriyanı Yenilə' : '➕ Yeni Kateqoriya'}
                </h3>
                <form onSubmit={handleSaveCategory} className="space-y-4">
                  <div>
                    <label className="block text-xs text-zinc-500 mb-1">Kateqoriya Adı</label>
                    <input 
                      type="text"
                      value={catInput}
                      onChange={(e) => setCatInput(e.target.value)}
                      placeholder="Məsələn: İdman"
                      className="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-zinc-300"
                    />
                  </div>
                  <div className="flex gap-2">
                    <button 
                      type="submit"
                      className="flex-1 bg-zinc-800 hover:bg-zinc-700 text-white py-2 rounded-lg text-sm font-medium transition-colors"
                    >
                      {editingCatId ? 'Yenilə' : 'Əlavə et'}
                    </button>
                    {editingCatId && (
                      <button 
                        type="button"
                        onClick={() => { setEditingCatId(null); setCatInput(''); }}
                        className="bg-zinc-200 hover:bg-zinc-300 text-zinc-600 px-3 py-2 rounded-lg text-sm font-medium transition-colors"
                      >
                        İmtina
                      </button>
                    )}
                  </div>
                </form>
              </div>

              {/* Sağ Cədvəl: Siyahı, Silmə və Düzəliş */}
              <div className="bg-white border border-zinc-200 rounded-xl p-6 shadow-sm lg:col-span-2">
                <h3 className="text-sm font-bold text-zinc-700 mb-4">Mövcud Kateqoriyalar</h3>
                {isCatsLoading ? (
                  <p className="text-sm text-zinc-400">Yüklənir...</p>
                ) : (
                  <div className="overflow-x-auto">
                    <table className="w-full text-left border-collapse">
                      <thead>
                        <tr className="border-b border-zinc-200 text-xs text-zinc-400 uppercase font-semibold">
                          <th className="pb-3">ID</th>
                          <th className="pb-3">Kateqoriya Adı</th>
                          <th className="pb-3 text-right">Əməliyyatlar</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-zinc-100 text-sm">
                        {serverCategories?.map((cat) => (
                          <tr key={cat._id} className="hover:bg-zinc-50/50">
                            <td className="py-3.5 text-zinc-400 font-mono text-xs">{cat._id}</td>
                            <td className="py-3.5 font-medium text-zinc-800">{cat.name}</td>
                            <td className="py-3.5 text-right space-x-3">
                              <button 
                                onClick={() => handleEditCategoryClick(cat._id, cat.name)}
                                className="text-blue-600 hover:text-blue-700 text-xs font-semibold"
                              >
                                Redaktə
                              </button>
                              <button 
                                onClick={() => handleDeleteCategory(cat._id)}
                                className="text-red-500 hover:text-red-600 text-xs font-semibold"
                              >
                                Sil
                              </button>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            </div>
          </div>
        )}

        {/* 3. TAB: XƏBƏR ƏLAVƏ ET */}
        {activeTab === 'news' && (
          <div className="max-w-2xl bg-white border border-zinc-200 rounded-xl p-6 shadow-sm">
            <h2 className="text-xl font-bold text-zinc-800 mb-6">📰 Yeni Xəbər Paylaşın</h2>
            
            <form onSubmit={handleAddNews} className="space-y-5">
              {/* Başlıq */}
              <div>
                <label className="block text-xs font-medium text-zinc-500 mb-1">Xəbərin Başlığı</label>
                <input 
                  type="text"
                  value={newsTitle}
                  onChange={(e) => setNewsTitle(e.target.value)}
                  placeholder="Başlığı daxil edin"
                  className="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-zinc-300"
                />
              </div>

              {/* API-dən gələn Dinamik Select Seçimi */}
              <div>
                <label className="block text-xs font-medium text-zinc-500 mb-1">Kateqoriya Seçin</label>
                <select
                  value={selectedCatId}
                  onChange={(e) => setSelectedCatId(e.target.value)}
                  className="w-full border border-zinc-200 bg-white rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-zinc-300 cursor-pointer"
                >
                  <option value="">-- Kateqoriya seçin --</option>
                  {serverCategories?.map((cat) => (
                    <option key={cat._id} value={cat._id}>
                      {cat.name}
                    </option>
                  ))}
                </select>
              </div>

              {/* Mətn */}
              <div>
                <label className="block text-xs font-medium text-zinc-500 mb-1">Xəbərin Məzmunu</label>
                <textarea 
                  rows={5}
                  value={newsContent}
                  onChange={(e) => setNewsContent(e.target.value)}
                  placeholder="Xəbər mətnini bura qeyd edin..."
                  className="w-full border border-zinc-200 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-zinc-300"
                />
              </div>

              {/* Düymə */}
              <button 
                type="submit"
                className="w-full bg-zinc-800 hover:bg-zinc-700 text-white py-2.5 rounded-lg text-sm font-medium transition-colors"
              >
                🚀 Xəbəri Sistemə Əlavə Et
              </button>
            </form>
          </div>
        )}

      </div>
    </div>
  )
}